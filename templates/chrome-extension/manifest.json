{
  "manifest_version": 3,
  "name": "Chrome Extension Boilerplate",
  "version": "1.0.0",
  "description": "Premium Manifest V3 extension template with Popup, Content Scripts, and Service Worker.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Open Sandbox Popup"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "storage",
    "activeTab"
  ],
  "host_permissions": []
}
